// Stdlib test: Amalgame.IO.FileWatcher — single-file mtime
// polling. Tests are mtime-free where possible (file
// disappearance / reappearance gives a deterministic Changed()
// flip without depending on filesystem timestamp resolution).

namespace Tests

import Amalgame.IO.FileWatcher

public class Program {
    public static void Main(string[] args) {

        let testPath: string = "/tmp/amc_fw_test.txt"

        // Clean slate.
        if (File.Exists(testPath)) {
            let _r: bool = File.Delete(testPath)
        }
        File.WriteAll(testPath, "v1")

        // ── Exists / GetPath on a present file ──
        let w = new FileWatcher(testPath)
        if (w.Exists()) {
            Console.WriteLine("[PASS] exists when present")
        } else {
            Console.WriteLine("[FAIL] exists when present")
        }
        if (w.GetPath() == testPath) {
            Console.WriteLine("[PASS] getpath")
        } else {
            Console.WriteLine("[FAIL] getpath")
        }

        // ── Changed() returns false on the immediate next call ──
        if (!w.Changed()) {
            Console.WriteLine("[PASS] no-change-on-init")
        } else {
            Console.WriteLine("[FAIL] no-change-on-init")
        }

        // ── Delete → Changed() flips true ──
        let _rm1: bool = File.Delete(testPath)
        if (w.Changed()) {
            Console.WriteLine("[PASS] detect-delete")
        } else {
            Console.WriteLine("[FAIL] detect-delete")
        }

        // ── After a true Changed(), next Changed() is false ──
        if (!w.Changed()) {
            Console.WriteLine("[PASS] reset-after-read")
        } else {
            Console.WriteLine("[FAIL] reset-after-read")
        }

        // ── Exists() reflects deletion ──
        if (!w.Exists()) {
            Console.WriteLine("[PASS] exists when absent")
        } else {
            Console.WriteLine("[FAIL] exists when absent")
        }

        // ── Re-create → Changed() flips true again ──
        File.WriteAll(testPath, "v2")
        if (w.Changed()) {
            Console.WriteLine("[PASS] detect-recreate")
        } else {
            Console.WriteLine("[FAIL] detect-recreate")
        }

        // Cleanup before the v2 surface tests.
        let _rm2: bool = File.Delete(testPath)

        // ── v2: FileWatcher.Poll() returns typed events ────
        let v2Path: string = "/tmp/amc_fw_v2_test.txt"
        if (File.Exists(v2Path)) {
            let _ = File.Delete(v2Path)
        }
        let pw = new FileWatcher(v2Path)
        // Absent → present yields one Created event.
        File.WriteAll(v2Path, "alpha")
        let pe1 = pw.Poll()
        if (pe1.Count() == 1 && pe1.Get(0).KindOf() == WatchEventKind.Created) {
            Console.WriteLine("[PASS] Poll emits Created on appearance")
        } else {
            Console.WriteLine("[FAIL] Poll emits Created on appearance")
        }
        // Quiescent.
        let pe2 = pw.Poll()
        if (pe2.Count() == 0) {
            Console.WriteLine("[PASS] Poll quiescent")
        } else {
            Console.WriteLine("[FAIL] Poll quiescent")
        }
        // Present → absent yields Deleted.
        let _rm3: bool = File.Delete(v2Path)
        let pe3 = pw.Poll()
        if (pe3.Count() == 1 && pe3.Get(0).KindOf() == WatchEventKind.Deleted) {
            Console.WriteLine("[PASS] Poll emits Deleted on disappearance")
        } else {
            Console.WriteLine("[FAIL] Poll emits Deleted on disappearance")
        }
        // Path is propagated correctly.
        if (pe3.Count() == 1 && pe3.Get(0).PathOf() == v2Path) {
            Console.WriteLine("[PASS] WatchEvent.PathOf")
        } else {
            Console.WriteLine("[FAIL] WatchEvent.PathOf")
        }
        // TimestampMs is non-zero (clock is set on every Linux build host).
        if (pe3.Count() == 1 && pe3.Get(0).TimestampMs() > 0) {
            Console.WriteLine("[PASS] WatchEvent.TimestampMs")
        } else {
            Console.WriteLine("[FAIL] WatchEvent.TimestampMs")
        }

        // ── v2: DirectoryWatcher (non-recursive) ────────────
        let dwDir: string = "/tmp/amc_dw_v2_test"
        let _setup = Process.Run("rm -rf '" + dwDir + "' && mkdir -p '" + dwDir + "'")
        let dw = new DirectoryWatcher(dwDir, false)
        if (dw.Count() == 0) {
            Console.WriteLine("[PASS] DirectoryWatcher empty snapshot")
        } else {
            Console.WriteLine("[FAIL] DirectoryWatcher empty snapshot, got " + String_FromInt(dw.Count()))
        }
        File.WriteAll(dwDir + "/a.txt", "alpha")
        File.WriteAll(dwDir + "/b.txt", "beta")
        let dwe1 = dw.Poll()
        if (dwe1.Count() == 2) {
            Console.WriteLine("[PASS] DirectoryWatcher detects 2 Created")
        } else {
            Console.WriteLine("[FAIL] DirectoryWatcher detects 2 Created, got " + String_FromInt(dwe1.Count()))
        }
        var allCreated: bool = true
        for ev in dwe1 {
            if (ev.KindOf() != WatchEventKind.Created) { allCreated = false }
        }
        if (allCreated) {
            Console.WriteLine("[PASS] DirectoryWatcher all events are Created")
        } else {
            Console.WriteLine("[FAIL] DirectoryWatcher all events are Created")
        }
        // Delete one.
        let _del1 = File.Delete(dwDir + "/a.txt")
        let dwe2 = dw.Poll()
        if (dwe2.Count() == 1 && dwe2.Get(0).KindOf() == WatchEventKind.Deleted) {
            Console.WriteLine("[PASS] DirectoryWatcher Deleted event")
        } else {
            Console.WriteLine("[FAIL] DirectoryWatcher Deleted event")
        }

        // ── v2: DirectoryWatcher recursive ──────────────────
        let rDir: string = "/tmp/amc_dw_v2_rec"
        let _r1 = Process.Run("rm -rf '" + rDir + "' && mkdir -p '" + rDir + "/sub'")
        let dwR = new DirectoryWatcher(rDir, true)
        File.WriteAll(rDir + "/top.txt", "T")
        File.WriteAll(rDir + "/sub/nested.txt", "N")
        let rEvs = dwR.Poll()
        if (rEvs.Count() == 2) {
            Console.WriteLine("[PASS] DirectoryWatcher recursive sees nested")
        } else {
            Console.WriteLine("[FAIL] DirectoryWatcher recursive count " + String_FromInt(rEvs.Count()))
        }

        // ── v2: DirectoryWatcher non-recursive ignores subdirs ─
        let nDir: string = "/tmp/amc_dw_v2_nonrec"
        let _n1 = Process.Run("rm -rf '" + nDir + "' && mkdir -p '" + nDir + "/sub'")
        let dwN = new DirectoryWatcher(nDir, false)
        File.WriteAll(nDir + "/top.txt", "T")
        File.WriteAll(nDir + "/sub/nested.txt", "N")
        let nEvs = dwN.Poll()
        if (nEvs.Count() == 1 && nEvs.Get(0).PathOf() == nDir + "/top.txt") {
            Console.WriteLine("[PASS] DirectoryWatcher non-recursive ignores subdirs")
        } else {
            Console.WriteLine("[FAIL] DirectoryWatcher non-recursive ignores subdirs (got " + String_FromInt(nEvs.Count()) + ")")
        }

        // Cleanup.
        let _c1 = Process.Run("rm -rf '" + dwDir + "' '" + rDir + "' '" + nDir + "'")

        // ── v0.4: backend introspection ─────────────────────
        // On Linux, the inotify backend is auto-selected. CI runs
        // on Ubuntu so we expect "inotify" here. On other OSes,
        // "polling" is the only choice and these would skip.
        let beProbePath: string = "/tmp/amc_fw_v04_backend.txt"
        File.WriteAll(beProbePath, "x")
        let beW = new FileWatcher(beProbePath)
        let beName: string = beW.BackendName()
        if (beName == "inotify" || beName == "polling") {
            Console.WriteLine("[PASS] FileWatcher.BackendName returns inotify or polling (got " + beName + ")")
        } else {
            Console.WriteLine("[FAIL] FileWatcher.BackendName unexpected " + beName)
        }
        let _ = File.Delete(beProbePath)

        // ── v0.4: inotify reactive — Modify detection ───────
        let nbDir: string = "/tmp/amc_fw_v04_react"
        let _nb = Process.Run("rm -rf '" + nbDir + "' && mkdir -p '" + nbDir + "'")
        let nbFile: string = nbDir + "/probe.txt"
        File.WriteAll(nbFile, "v1")
        let nbW = new FileWatcher(nbFile)
        if (nbW.BackendName() == "inotify") {
            // Modify via append. inotify delivers IN_MODIFY
            // synchronously via the file-table commit; a brief
            // sleep before Poll avoids racy CI runners.
            let _wr = Process.Run("sh -c 'echo y >> " + nbFile + " && sleep 0.1'")
            let nbEvs = nbW.Poll()
            var sawMod: bool = false
            for ev in nbEvs {
                if (ev.KindOf() == WatchEventKind.Modified) { sawMod = true }
            }
            if (sawMod) {
                Console.WriteLine("[PASS] inotify detects Modify in real time")
            } else {
                Console.WriteLine("[FAIL] inotify Modify count=" + String_FromInt(nbEvs.Count()))
            }

            // Atomic-rename recovery — delete then re-create.
            let _del = File.Delete(nbFile)
            let _sl1 = Process.Run("sh -c 'sleep 0.1'")
            File.WriteAll(nbFile, "v3")
            let _sl2 = Process.Run("sh -c 'sleep 0.1'")
            let nbEvs2 = nbW.Poll()
            var sawDel: bool = false
            var sawCre: bool = false
            for ev in nbEvs2 {
                if (ev.KindOf() == WatchEventKind.Deleted) { sawDel = true }
                if (ev.KindOf() == WatchEventKind.Created) { sawCre = true }
            }
            if (sawDel && sawCre) {
                Console.WriteLine("[PASS] inotify atomic-rename recovery (Delete+Create)")
            } else {
                Console.WriteLine("[FAIL] inotify rename del=" + String_FromInt(sawDel) + " cre=" + String_FromInt(sawCre))
            }
        } else {
            Console.WriteLine("[SKIP] inotify detects Modify in real time (non-Linux)")
            Console.WriteLine("[SKIP] inotify atomic-rename recovery (Delete+Create) (non-Linux)")
        }
        let _ncleanup = Process.Run("rm -rf '" + nbDir + "'")

        // ── v0.4: DirectoryWatcher recursive picks up new
        //   subdir's children (race between mkdir + populate). ──
        let nsDir: string = "/tmp/amc_fw_v04_newsub"
        let _ns = Process.Run("rm -rf '" + nsDir + "' && mkdir -p '" + nsDir + "'")
        let nsW = new DirectoryWatcher(nsDir, true)
        if (nsW.BackendName() == "inotify") {
            let _mk = Process.Run("sh -c 'mkdir " + nsDir + "/newdir && sleep 0.05 && echo z > " + nsDir + "/newdir/z.txt && sleep 0.2'")
            let nsEvs = nsW.Poll()
            var sawZ: bool = false
            for ev in nsEvs {
                if (ev.PathOf() == nsDir + "/newdir/z.txt") { sawZ = true }
            }
            if (sawZ) {
                Console.WriteLine("[PASS] inotify recursive picks up new subdir's file")
            } else {
                Console.WriteLine("[FAIL] inotify recursive new-subdir " + String_FromInt(nsEvs.Count()) + " events")
            }
        } else {
            Console.WriteLine("[SKIP] inotify recursive picks up new subdir's file (non-Linux)")
        }
        let _nscleanup = Process.Run("rm -rf '" + nsDir + "'")

        // ── v0.5: rename pairing — IN_MOVED_FROM + IN_MOVED_TO
        //   sharing a cookie collapse into one Renamed event with
        //   both paths. Unpaired Moved events fall back to
        //   Deleted (file left the watched tree) or Created
        //   (file moved in from outside).
        let rnDir: string = "/tmp/amc_fw_v05_rename"
        let _rn = Process.Run("rm -rf '" + rnDir + "' && mkdir -p '" + rnDir + "' && echo a > '" + rnDir + "/a.txt'")
        let rnW = new DirectoryWatcher(rnDir, false)
        if (rnW.BackendName() == "inotify") {
            // Rename within the watched dir.
            let _mv = Process.Run("sh -c 'mv " + rnDir + "/a.txt " + rnDir + "/b.txt && sleep 0.2'")
            let rnEvs = rnW.Poll()
            var sawRename: bool = false
            for ev in rnEvs {
                if (ev.KindOf() == WatchEventKind.Renamed
                    && ev.PathOf() == rnDir + "/a.txt"
                    && ev.RenamedToOf() == rnDir + "/b.txt") {
                    sawRename = true
                }
            }
            if (sawRename) {
                Console.WriteLine("[PASS] rename within watched dir → Renamed event with both paths")
            } else {
                Console.WriteLine("[FAIL] rename pairing inside dir, count=" + String_FromInt(rnEvs.Count()))
            }

            // Move out of watched dir → unpaired MovedFrom → Deleted.
            let outDir: string = "/tmp/amc_fw_v05_outside"
            let _mo = Process.Run("rm -rf '" + outDir + "' && mkdir -p '" + outDir + "' && mv " + rnDir + "/b.txt " + outDir + "/b.txt && sleep 0.2")
            let outEvs = rnW.Poll()
            var sawDel: bool = false
            for ev in outEvs {
                if (ev.KindOf() == WatchEventKind.Deleted && ev.PathOf() == rnDir + "/b.txt") {
                    sawDel = true
                }
            }
            if (sawDel) {
                Console.WriteLine("[PASS] move out of watched dir → Deleted")
            } else {
                Console.WriteLine("[FAIL] move out → Deleted, count=" + String_FromInt(outEvs.Count()))
            }

            // Move in from outside → unpaired MovedTo → Created.
            let _mi = Process.Run("sh -c 'mv " + outDir + "/b.txt " + rnDir + "/b.txt && sleep 0.2'")
            let inEvs = rnW.Poll()
            var sawCre: bool = false
            for ev in inEvs {
                if (ev.KindOf() == WatchEventKind.Created && ev.PathOf() == rnDir + "/b.txt") {
                    sawCre = true
                }
            }
            if (sawCre) {
                Console.WriteLine("[PASS] move into watched dir → Created")
            } else {
                Console.WriteLine("[FAIL] move in → Created, count=" + String_FromInt(inEvs.Count()))
            }
            let _outclean = Process.Run("rm -rf '" + outDir + "'")
        } else {
            Console.WriteLine("[SKIP] rename within watched dir → Renamed event with both paths (non-Linux)")
            Console.WriteLine("[SKIP] move out of watched dir → Deleted (non-Linux)")
            Console.WriteLine("[SKIP] move into watched dir → Created (non-Linux)")
        }
        let _rncleanup = Process.Run("rm -rf '" + rnDir + "'")
    }
}
